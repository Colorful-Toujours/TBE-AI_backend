generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id
  name         String
  phone        String   @unique
  email        String?
  avatar       String?
  role         String
  status       String
  passwordSalt String?  @map("password_salt")
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model SmsCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  scene     String
  expiresAt DateTime @map("expires_at")
  sentAt    DateTime @map("sent_at")

  @@index([phone, scene])
  @@map("sms_codes")
}

model TokenBlacklist {
  jti       String   @id
  createdAt DateTime @default(now()) @map("created_at")

  @@map("token_blacklist")
}

model Material {
  id        String  @id
  name      String
  category  String
  unit      String
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  stock     Int
  remark    String?

  @@map("materials")
}

model Bill {
  id         String  @id
  date       String
  user       String
  community  String
  unit       String
  receivable Decimal @db.Decimal(12, 2)
  received   Decimal @db.Decimal(12, 2)
  materials  Json    @default("[]")

  @@map("bills")
}

model Payment {
  id      String    @id
  amount  Decimal   @db.Decimal(12, 2)
  status  String
  email   String
  billId  String?   @map("bill_id")
  paidAt  DateTime? @map("paid_at")
  channel String?

  @@map("payments")
}

model AuditLog {
  id         String   @id
  createdAt  DateTime @default(now()) @map("created_at")
  operator   String
  operatorId String?  @map("operator_id")
  action     String
  module     String
  target     String
  detail     String?
  status     String

  @@index([createdAt])
  @@map("audit_logs")
}
